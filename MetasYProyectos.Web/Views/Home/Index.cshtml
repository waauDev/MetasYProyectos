@{
    ViewData["Title"] = "Inicio";
}

<div class="page-heading">
    <div class="page-pretitle">Panel principal</div>
    <h3 class="page-title">Bienvenido a Metas y Proyectos</h3>
</div>

<div class="row row-cards">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="subheader-icon me-3">
                        <i class="ti ti-target-arrow text-primary"></i>
                    </div>
                    <div>
                        <div class="subheader text-muted">Módulo principal</div>
                        <h3 class="card-title mb-0">Metas y Proyectos</h3>
                    </div>
                </div>
                <p class="text-muted mt-3">Gestiona las metas y proyectos del sistema.</p>
                <a asp-controller="MetasProyectos" asp-action="Index" class="btn btn-primary">
                    <i class="ti ti-arrow-right me-1"></i> Entrar
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="subheader-icon me-3">
                        <i class="ti ti-database text-primary"></i>
                    </div>
                    <div>
                        <div class="subheader text-muted">Configuración</div>
                        <h3 class="card-title mb-0">Conexiones Oracle</h3>
                    </div>
                </div>
                <p class="text-muted mt-3">Administra las conexiones a bases de datos Oracle.</p>
                <a asp-controller="Configuracion" asp-action="Index" class="btn btn-outline-primary">
                    <i class="ti ti-settings me-1"></i> Configurar
                </a>
            </div>
        </div>
    </div>
</div>
