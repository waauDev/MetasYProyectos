@model List<MetasYProyectos.Web.ViewModels.ConfiguracionViewModel>
@{
    ViewData["Title"] = "Configuraciones de base de datos";
}

<div class="page-heading">
    <div class="page-pretitle">Configuración</div>
    <h3 class="page-title">Conexiones configuradas</h3>
</div>

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">
        <i class="ti ti-check-circle me-1"></i> @TempData["Ok"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="ti ti-alert-triangle me-1"></i> @TempData["Error"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted">Administra las conexiones a servidores Oracle</small>
    </div>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="ti ti-plus me-1"></i> Nueva conexión
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="ti ti-database-off display-4 text-muted"></i>
            <p class="mt-3 text-muted">No hay conexiones configuradas</p>
            <a asp-action="Crear" class="btn btn-primary">
                <i class="ti ti-plus me-1"></i> Agregar primera conexión
            </a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover table-vcenter card-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Servidor</th>
                        <th>Puerto</th>
                        <th>Servicio</th>
                        <th>Usuario</th>
                        <th>Oracle</th>
                        <th>Tipo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cfg in Model)
                    {
                        <tr>
                            <td><strong>@cfg.Nombre</strong></td>
                            <td>@cfg.Servidor</td>
                            <td>@cfg.Puerto</td>
                            <td>@cfg.Servicio</td>
                            <td>@cfg.Usuario</td>
                            <td>@cfg.Version</td>
                            <td>@cfg.TipoConexion</td>
                            <td class="text-end">
                                <a asp-action="Editar" asp-route-nombre="@cfg.Nombre" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="ti ti-pencil"></i>
                                </a>
                                <form asp-action="Eliminar" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar la configuración @cfg.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="nombre" value="@cfg.Nombre" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="ti ti-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
