@model string
@{
    ViewData["Title"] = "Contraseña restablecida";
    Layout = "_Layout";
}

<div class="page-heading">
    <div class="page-pretitle">Administración</div>
    <h3 class="page-title">Contraseña restablecida</h3>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4 text-center">
                <i class="ti ti-circle-check-filled display-4 text-success"></i>
                <h4 class="mt-2">Contraseña restablecida</h4>
                <p class="text-muted small mb-4">
                    Se generó un <strong>nuevo</strong> código de recuperación. El anterior ya no es válido.
                    Guarda este código en un lugar seguro.
                </p>

                <div class="bg-light border rounded p-3 mb-4">
                    <code class="fs-5 fw-bold">@Model</code>
                </div>

                <a asp-controller="Admin" asp-action="Login" class="btn btn-primary w-100">
                    Ir al inicio de sesión
                </a>
            </div>
        </div>
    </div>
</div>
