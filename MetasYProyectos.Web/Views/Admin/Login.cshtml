@{
    ViewData["Title"] = "Iniciar sesión - Admin";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-sm border-0" style="max-width: 400px; width: 100%;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="bi bi-lock display-5 text-primary"></i>
                <h4 class="mt-2 mb-0">Acceso administrador</h4>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Admin">
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Contraseña</label>
                    <input type="password" name="password" class="form-control" autofocus required />
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-2">Ingresar</button>
            </form>

            <div class="text-center mt-3">
                <a asp-controller="Admin" asp-action="Reset" class="small text-decoration-none">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>
        </div>
    </div>
</div>