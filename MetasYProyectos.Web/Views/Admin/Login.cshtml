@{
    ViewData["Title"] = "Iniciar sesión - Admin";
    Layout = "_Layout";
}

<div class="page-heading">
    <div class="page-pretitle">Administración</div>
    <h3 class="page-title">Acceso administrador</h3>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="ti ti-lock display-4 text-primary"></i>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post" asp-action="Login" asp-controller="Admin">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Contraseña</label>
                        <input type="password" name="password" class="form-control" autofocus required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mb-2">Ingresar</button>
                </form>

                <div class="text-center mt-3">
                    <a asp-controller="Admin" asp-action="Reset" class="small text-decoration-none">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
