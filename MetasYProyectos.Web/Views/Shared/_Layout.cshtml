<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>@ViewData["Title"] - Metas y Proyectos</title>

    <link rel="stylesheet" href="~/lib/tabler/dist/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/tabler/dist/css/tabler-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/toastify-js/toastify.min.css" />
</head>
<body>
    <div class="page">
        <!-- Sidebar -->
        <aside class="navbar navbar-vertical navbar-expand-sm" data-bs-theme="dark">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false" aria-label="Alternar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <h1 class="navbar-brand navbar-brand-autodark">
                    <a href="/">
                        <span class="brand-link">
                            <span class="brand-dot"></span>Metas y Proyectos
                        </span>
                    </a>
                </h1>
                <div class="collapse navbar-collapse" id="sidebar-menu">
                    <ul class="navbar-nav pt-lg-3">
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                            <a class="nav-link" href="/">
                                <span class="nav-link-icon">
                                    <i class="ti ti-home"></i>
                                </span>
                                <span class="nav-link-title">Inicio</span>
                            </a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Configuracion" ? "active" : "")">
                            <a class="nav-link" href="/Configuracion">
                                <span class="nav-link-icon">
                                    <i class="ti ti-database"></i>
                                </span>
                                <span class="nav-link-title">Configuración</span>
                            </a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "MetasProyectos" ? "active" : "")">
                            <a class="nav-link" href="/MetasProyectos">
                                <span class="nav-link-icon">
                                    <i class="ti ti-target-arrow"></i>
                                </span>
                                <span class="nav-link-title">Metas y Proyectos</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </aside>

        <div class="page-wrapper">
            <div class="page-header d-print-none">
                <div class="container-xl">
                    <div class="page-pretitle">Metas y Proyectos</div>
                    <h2 class="page-title">@ViewData["Title"]</h2>
                </div>
            </div>

            <div class="page-body">
                <div class="container-xl">
                    @if (TempData["Error"] is string layoutError)
                    {
                        <input type="hidden" data-toast="Error" value="@layoutError" />
                    }
                    @if (TempData["Ok"] is string layoutOk)
                    {
                        <input type="hidden" data-toast="Exito" value="@layoutOk" />
                    }
                    @RenderBody()
                </div>
            </div>

            <footer class="footer footer-transparent d-print-none">
                <div class="container-xl">
                    <div class="row text-center align-items-center flex-row-reverse">
                        <div class="col-lg-auto ms-lg-auto">
                            <ul class="list-inline list-inline-dots mb-0">
                                <li class="list-inline-item">
                                    <form asp-controller="Login" asp-action="CerrarSesion" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link btn-sm text-decoration-none">
                                            <i class="ti ti-logout me-1"></i> Cerrar sesión
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                            <ul class="list-inline list-inline-dots mb-0">
                                <li class="list-inline-item">
                                    &copy; @DateTime.Now.Year Metas y Proyectos
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/tabler/dist/js/tabler.min.js" asp-append-version="true"></script>
    <script src="~/lib/toastify-js/toastify.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
